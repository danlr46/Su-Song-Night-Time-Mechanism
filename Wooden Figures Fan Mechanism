import math
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.patches import Circle, Rectangle, Arc, Polygon

# =========================================================
# SCHEMATIC: 31-rib fan with Ø200 cm cam disc stacked above
# a Ø30 cm gear wheel driven by a Ø30 cm pinion.
# Ribs 120 cm. Opening 144.95°–215.00°, symmetric about vertical axis.
# Direct matplotlib version -> PNG output
# =========================================================

# ---- physical parameters ----
RIB_LEN_CM   = 120
CAM_D_CM     = 200
GEAR_D_CM    = 30
PINION_D_CM  = 60
N_RIBS       = 31
ANGLE_MIN    = 144.95
ANGLE_MAX    = 215.00

CAM_R       = CAM_D_CM / 2
GEAR_R      = GEAR_D_CM / 2
PINION_R    = PINION_D_CM / 2
TOOTH_H     = 1.8
PIVOT_R     = 2.6

# follower pins spread radially across most of the cam face
PIN_R_MIN   = 0.42 * CAM_R
PIN_R_MAX   = 0.93 * CAM_R

# ---- geometry layout ----
cx, cy = 0.0, 0.0   # plan-view pivot in cm

# section layout
sx, sy = 240.0, -5.0

# ---------------------------------------------------------
# helpers
# ---------------------------------------------------------

def pt(ang_deg, r, ox=cx, oy=cy):
    a = math.radians(ang_deg)
    return (ox + r * math.cos(a), oy + r * math.sin(a))

def rib_angles(span):
    spacing = span / (N_RIBS - 1)
    return [90 + (i - (N_RIBS - 1) / 2) * spacing for i in range(N_RIBS)]

open_max = rib_angles(ANGLE_MAX)
open_min = rib_angles(ANGLE_MIN)

def pin_radius(i):
    t = i / (N_RIBS - 1)
    if i % 2 == 0:
        return PIN_R_MIN + t * (PIN_R_MAX - PIN_R_MIN)
    else:
        return PIN_R_MAX - t * (PIN_R_MAX - PIN_R_MIN)

def gear_outline_xy(gx, gy, r_pitch, n_teeth, tooth_h, start_angle=0):
    r_tip  = r_pitch + tooth_h / 2
    r_root = r_pitch - tooth_h / 2
    pts = []
    total = n_teeth * 4
    for i in range(total):
        theta = start_angle + i * 360 / total
        r = r_root if (i % 4) in (0, 3) else r_tip
        a = math.radians(theta)
        pts.append((gx + r * math.cos(a), gy + r * math.sin(a)))
    return pts

def spiral_points(theta_end, r_end, ox=cx, oy=cy):
    pts = []
    sweep = 28   # reduced angular sweep because the disc is much larger
    r_start = max(8, r_end - 0.22 * CAM_R)
    for t in np.linspace(0, 1, 41):
        ang = theta_end + sweep * (1 - t)
        r = r_start + (r_end - r_start) * t
        pts.append(pt(ang, r, ox, oy))
    return np.array(pts)

def add_rotation_arrow(ax, center, radius, theta1, theta2, color, lw=1.6):
    arc = Arc(center, 2*radius, 2*radius, angle=0, theta1=theta1, theta2=theta2,
              color=color, lw=lw)
    ax.add_patch(arc)

    th = math.radians(theta2)
    xh = center[0] + radius * math.cos(th)
    yh = center[1] + radius * math.sin(th)

    tangent = th + math.pi/2
    dx = 3.0 * math.cos(tangent)
    dy = 3.0 * math.sin(tangent)

    ax.annotate(
        "",
        xy=(xh, yh),
        xytext=(xh - dx, yh - dy),
        arrowprops=dict(arrowstyle="-|>", color=color, lw=lw, mutation_scale=11)
    )

def add_leader(ax, xf, yf, xt, yt, text, color="#444", ha="left", size=9):
    ax.plot([xf, xt], [yf, yt], color="#999", lw=0.8)
    ax.text(xt, yt, " " + text if ha == "left" else text + " ",
            fontsize=size, color=color, ha=ha, va="center")

# ---------------------------------------------------------
# figure
# ---------------------------------------------------------

