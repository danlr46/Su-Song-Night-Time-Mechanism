y4 = 25      # fourth level
y5 = -35     # fifth level

# level lines
ax2.plot([x0-110, x0+110], [y4, y4], color="black", lw=1.2)
ax2.plot([x0-110, x0+110], [y5, y5], color="firebrick", lw=1.2)

ax2.text(x0-112, y4+5, "fourth level\nphase control", fontsize=9,
         color="black", ha="right", va="center")
ax2.text(x0-112, y5+5, "fifth level\nfan mechanism", fontsize=9,
         color="firebrick", ha="right", va="center")

# gear radii in section drawing, scaled schematically
r15 = 10
r30 = 18
thick = 5

# gear centers in section
g1x = x0 - 35   # phase-control gear, Ø15
g2x = x0 + 20   # upper driving wheel, Ø30
g3x = x0 + 20   # lower driving wheel, Ø30, same vertical shaft
g4x = x0 - 35   # cam gear, Ø15

# ---------------------------------------------------------
# fourth level gears
# ---------------------------------------------------------

# G1 Ø15
ax2.add_patch(Rectangle((g1x-r15, y4-thick/2), 2*r15, thick,
                        facecolor="#e6d29a", edgecolor="black", lw=1.0))
ax2.text(g1x, y4+11, "G1\nØ15", fontsize=8, ha="center", va="bottom")

# G2 Ø30
ax2.add_patch(Rectangle((g2x-r30, y4-thick/2), 2*r30, thick,
                        facecolor="#e6d29a", edgecolor="black", lw=1.0))
ax2.text(g2x, y4+13, "G2\nØ30", fontsize=8, ha="center", va="bottom")

# mesh G1-G2
ax2.plot([g1x+r15, g2x-r30], [y4, y4],
         color="#c0392b", lw=0.8, dashes=(2, 2))
ax2.text((g1x+r15+g2x-r30)/2, y4+4, "15:30", fontsize=8,
         color="#c0392b", ha="center")

# selected arrow / phase input
ax2.arrow(g1x-38, y4, 26, 0,
          head_width=3, head_length=5, fc="green", ec="green", lw=1.2)
ax2.text(g1x-42, y4+7, "phase-control\narrow", fontsize=8,
         color="green", ha="right")

# ---------------------------------------------------------
# vertical shaft G2-G3
# ---------------------------------------------------------

ax2.plot([g2x, g3x], [y4-thick/2, y5+thick/2],
         color="darkred", lw=2.0)
ax2.text(g2x+7, (y4+y5)/2,
         "common\nvertical shaft", fontsize=8,
         color="darkred", ha="left", va="center")

# ---------------------------------------------------------
# fifth level gears
# ---------------------------------------------------------

# G3 Ø30
ax2.add_patch(Rectangle((g3x-r30, y5-thick/2), 2*r30, thick,
                        facecolor="#f0d0d0", edgecolor="firebrick", lw=1.0))
ax2.text(g3x, y5-12, "G3\nØ30", fontsize=8, color="firebrick",
         ha="center", va="top")

# G4 Ø15
ax2.add_patch(Rectangle((g4x-r15, y5-thick/2), 2*r15, thick,
                        facecolor="#f0d0d0", edgecolor="firebrick", lw=1.0))
ax2.text(g4x, y5-12, "G4\nØ15", fontsize=8, color="firebrick",
         ha="center", va="top")

# mesh G3-G4
ax2.plot([g4x+r15, g3x-r30], [y5, y5],
         color="#c0392b", lw=0.8, dashes=(2, 2))
ax2.text((g4x+r15+g3x-r30)/2, y5+4, "30:15", fontsize=8,
         color="#c0392b", ha="center")

# cam disc on fifth level
cam_sec_w = 95
cam_sec_h = 7
cam_y = y5 + 18

ax2.add_patch(Rectangle((x0-cam_sec_w/2, cam_y-cam_sec_h/2),
                        cam_sec_w, cam_sec_h,
                        facecolor="#c8d2ee", edgecolor="#3b4c82", lw=1.0))
ax2.text(x0+cam_sec_w/2+8, cam_y,
         "cam disc\nØ200", fontsize=8, color="#3b4c82",
         ha="left", va="center")

# coupling G4 to cam disc
ax2.plot([g4x, g4x], [y5+thick/2, cam_y-cam_sec_h/2],
         color="#3b4c82", lw=1.2)

# rib stack above cam disc
rib_y = cam_y + 15
stack_w = 90
stack_h = 12

for k in range(N_RIBS):
    yy = rib_y + k * stack_h / N_RIBS
    ax2.add_patch(Rectangle((x0-stack_w/2, yy),
                            stack_w, stack_h/N_RIBS,
                            facecolor="#8b5a2b", edgecolor="#503020",
                            lw=0.12))

ax2.text(x0+stack_w/2+8, rib_y+stack_h/2,
         "rib stack\nwooden figures", fontsize=8,
         color="#6b4423", ha="left", va="center")

# follower pins from cam disc to ribs
for dx in [-36, -24, -12, 0, 12, 24, 36]:
    ax2.plot([x0+dx, x0+dx],
             [cam_y+cam_sec_h/2, rib_y+stack_h],
             color="#c0392b", lw=1.0)

# central pivot / axle of fan
ax2.plot([x0, x0], [y5-12, rib_y+stack_h+8],
         color="#2d2d2d", lw=2.0)
ax2.text(x0-8, rib_y+stack_h+8,
         "central pivot", fontsize=8,
         color="#111", ha="right", va="bottom")

# explanatory note
ax2.text(x0, -75,
         "G1→G2 = 15:30 and G3→G4 = 30:15\n"
         "overall ratio = 1; two gear engagements preserve rotation sense",
         fontsize=8.5, color="#333", ha="center", va="center")

ax2.set_xlim(95, 365)
ax2.set_ylim(-90, 65)

# =========================================================
# NOTES BOX
# =========================================================
notes = [
    "• 31 ribs (L = 120 cm) on the fifth level share a single central pivot and are driven by spiral slots machined into a cam disc (Ø 200 cm).",
    "• The large diameter ensures well-separated slots and smooth follower motion, allowing a sufficiently fine discretization of the annual cycle (61 positions).",
    "• The rib assembly is actuated by a cam gear (Ø ≈ 15 cm), driven by a Ø 30 cm wheel rigidly coupled to a corresponding wheel on the fourth level.",
    "• The phase-control mechanism is located on the fourth level; the fan mechanism is on the fifth level. The two are connected by a common vertical shaft.",
    "• Kinematic chain: the phase-control arrow sets the phase-control gear wheel (Ø 15 cm), which drives the upper driving wheel (Ø 30 cm)",
    "  the motion is transmitted to the lower driving wheel (Ø 30 cm) and then to the cam gear (Ø 15 cm).",
    "• The gear pairs (15:30 and 30:15) are reciprocal, giving a unit overall ratio; with two gear engagements, the direction of rotation is preserved.",
    "• The imposed angular displacement is transmitted unchanged to the cam system, which converts it into radial motion of the ribs, opening or closing the fan.",
    "• The fan opens symmetrically about the vertical axis between 144.95° and 215.00° (total stroke 70.05°)."
]

y0 = 0.12
fig.text(0.05, y0+0.085, "Working principle & architecture",
         fontsize=14, fontweight="bold", color="#8a6d1a")
for i, txt in enumerate(notes):
    fig.text(0.05, y0+0.063 - i*0.018, txt, fontsize=8.8, color="#3f3f3f")

