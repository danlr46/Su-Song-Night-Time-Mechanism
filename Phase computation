# --- SEASONAL SUNSET CAM – Kaifeng latitude (INVERTED KINEMATICS, CONTINUOUS BRANCH) ---
# Inner disc 235 cm, outer disc 250 cm, 61 holes.
# Gear pair: central gear r=15 cm (at the center), output gear r=30 cm (tangent).
# The hole profile is computed by inverting the kinematics in order to obtain
# the desired angular variation of the release lever.
# The branch is chosen continuously in order to avoid jumps after mid-year.
#
# UPDATE:
# The 39 night figures are no longer generic, but follow the historical sequence:
# 1 red   = sunset
# 1 green = curfew
# 5 geng  = 5 × [1 red + 4 green] = 25
# 10 green = waiting for dawn
# 1 green = pre-dawn (xiao)
# 1 red   = sunrise
#
# Total: 39 signals
# Generated by ChatGPT


import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
from math import pi

# ---------------------------------------------------------
# General parameters
# ---------------------------------------------------------

LAT_DEG = 34.80
NDAYS   = 365

# Disc geometry
DIAM_INNER = 235.0
DIAM_OUTER = 250.0
R_INNER = DIAM_INNER / 2.0
R_OUTER = DIAM_OUTER / 2.0

# Cam and rod parameters
R0_CAM_CM     = 100.0
ROD_LENGTH_CM = 100.0

# Phase conversion (hours) -> ideal lever angle (output)
DEG_PER_HOUR = 15.0

# Gear pair
R_GEAR_CENTRAL = 15.0
R_GEAR_OUTPUT  = 30.0
GEAR_RATIO = R_GEAR_CENTRAL / R_GEAR_OUTPUT

# Gear positions
GEAR_CENTRAL_CX, GEAR_CENTRAL_CY = 0.0, 0.0
GEAR_OUTPUT_CX,  GEAR_OUTPUT_CY  = R_GEAR_CENTRAL + R_GEAR_OUTPUT, 0.0

# Night figures
N_FIG = 39
MEAN_NIGHT_ARC_DEG = 180.0
NIGHT_CENTER_DEG   = 180.0

# ---------------------------------------------------------
# Support functions
# ---------------------------------------------------------

def deg2rad(x):
    return x * pi / 180.0

def rad2deg(x):
    return x * 180.0 / pi

def solar_declination_cooper(N):
    return deg2rad(23.45) * np.sin(np.deg2rad(360.0 * (284.0 + N) / 365.0))

def day_length_hours(latitude_deg, delta_rad):
    phi = deg2rad(latitude_deg)
    x   = -np.tan(phi) * np.tan(delta_rad)
    x   = np.clip(x, -1.0, 1.0)
    H0  = np.arccos(x)
    return (2.0 * rad2deg(H0)) / 15.0

def build_night_sequence():
    """
    Returns the correct sequence of the 39 night signals.
    Each element is a dictionary with:
    - index
    - label
    - color_name
    - color_plot
    """
    seq = []

    # 1) Sunset
    seq.append({
        "index": 1,
        "label": "sunset",
        "color_name": "red",
        "color_plot": "red"
    })

    # 2) Curfew
    seq.append({
        "index": 2,
        "label": "curfew",
        "color_name": "green",
        "color_plot": "green"
    })

    # 3) 5 geng = 5 × [1 red + 4 green]
    idx = 3
    for g in range(1, 6):
        seq.append({
            "index": idx,
            "label": f"geng_{g}_start",
            "color_name": "red",
            "color_plot": "red"
        })
        idx += 1

        for j in range(1, 5):
            seq.append({
                "index": idx,
                "label": f"geng_{g}_interval_{j}",
                "color_name": "green",
                "color_plot": "green"
            })
            idx += 1

    # 4) Waiting for dawn = 10 green signals
    for k in range(1, 11):
        seq.append({
            "index": idx,
            "label": f"wait_dawn_{k}",
            "color_name": "green",
            "color_plot": "green"
        })
        idx += 1

    # 5) Pre-dawn
    seq.append({
        "index": idx,
        "label": "xiao_pre_dawn",
        "color_name": "green",
        "color_plot": "green"
    })
    idx += 1

    # 6) Sunrise
    seq.append({
        "index": idx,
        "label": "sunrise",
        "color_name": "red",
        "color_plot": "red"
    })

    assert len(seq) == 39
    return seq

NIGHT_SEQUENCE = build_night_sequence()

def compute_night_figures_positions(night_length_hours,
                                    mean_night_length_hours,
                                    n_fig=N_FIG,
                                    r_outer=R_OUTER,
                                    mean_arc_deg=MEAN_NIGHT_ARC_DEG,
                                    center_deg=NIGHT_CENTER_DEG):
    """
    Distributes the 39 signals along the night arc,
    proportional to the duration of the night, symmetrically
    with respect to the central axis of the mean night.
    """
    night_arc_deg = mean_arc_deg * (night_length_hours / mean_night_length_hours)
    half_arc_deg  = night_arc_deg / 2.0

    start_deg = center_deg - half_arc_deg
    end_deg   = center_deg + half_arc_deg

    angles_deg = np.linspace(start_deg, end_deg, n_fig)
    angles_rad = np.deg2rad(angles_deg)

    x = r_outer * np.cos(angles_rad)
    y = r_outer * np.sin(angles_rad)

    return {
        "night_length_hours": night_length_hours,
        "night_arc_deg": night_arc_deg,
        "start_deg": start_deg,
        "end_deg": end_deg,
        "center_deg": center_deg,
        "angles_deg": angles_deg,
        "angles_rad": angles_rad,
        "x": x,
        "y": y
    }

def line_from_output_gear_to_outer_disc(angle_rad, cx=GEAR_OUTPUT_CX, cy=GEAR_OUTPUT_CY, rdisk=R_OUTER):
    """
    Given a trigger angle with respect to the center of the output gear,
    returns the segment that starts from the center of the output gear
    and reaches the outer disc.
    """
    ux = np.cos(angle_rad)
    uy = np.sin(angle_rad)

    Cu  = cx * ux + cy * uy
    C2  = cx**2 + cy**2

    A_q = 1.0
    B_q = 2.0 * Cu
    C_q = C2 - rdisk**2

    disc_q = B_q**2 - 4.0 * A_q * C_q
    if disc_q < 0:
        return None

    sqrt_disc_q = np.sqrt(disc_q)
    t1 = (-B_q + sqrt_disc_q) / (2.0 * A_q)
    t2 = (-B_q - sqrt_disc_q) / (2.0 * A_q)

    ts = [t for t in (t1, t2) if t > 0]
    if len(ts) == 0:
        return None

    t = min(ts)
    x1 = cx + t * ux
    y1 = cy + t * uy
    return (cx, cy, x1, y1)

def draw_base_mechanism(ax,
                        hole_x, hole_y,
                        radius_cam_all, theta_all,
                        trigger_geom_deg,
                        title=None):
    """
    Draws the general mechanism diagram:
    - discs
    - gears
    - complete cam
    - 61 holes
    - green arrows
    - blue triggers
    """
    # Outer disc
    outer_circle = plt.Circle((0, 0), R_OUTER, fill=False, linewidth=1.5, linestyle='-')
    ax.add_patch(outer_circle)

    # Inner disc
    inner_circle = plt.Circle((0, 0), R_INNER, fill=False, linewidth=1.5, linestyle='--')
    ax.add_patch(inner_circle)

    # Central gear
    gear_central = plt.Circle((GEAR_CENTRAL_CX, GEAR_CENTRAL_CY),
                              R_GEAR_CENTRAL, fill=False, linewidth=1.5,
                              linestyle='-.', label="Central gear (r=15 cm)")
    ax.add_patch(gear_central)

    # Output gear
    gear_output = plt.Circle((GEAR_OUTPUT_CX, GEAR_OUTPUT_CY),
                             R_GEAR_OUTPUT, fill=False, linewidth=1.5,
                             linestyle=':', label="Output gear (r=30 cm)")
    ax.add_patch(gear_output)

    # 61 holes
    ax.scatter(hole_x, hole_y, s=25, c='black', label="61 cam holes")

    # Complete cam profile
    cam_x_all = radius_cam_all * np.cos(theta_all)
    cam_y_all = radius_cam_all * np.sin(theta_all)
    ax.plot(cam_x_all, cam_y_all, color='lightgray', linewidth=1.0,
            label="Cam profile (all days)")

    # Green arrows: from the center to the 61 holes
    for xh, yh in zip(hole_x, hole_y):
        ax.plot([GEAR_CENTRAL_CX, xh], [GEAR_CENTRAL_CY, yh], color='green', alpha=0.5)

    # Blue triggers
    trigger_geom_rad = deg2rad(trigger_geom_deg)
    for ang in trigger_geom_rad:
        seg = line_from_output_gear_to_outer_disc(ang)
        if seg is None:
            continue
        x0, y0, x1, y1 = seg
        ax.plot([x0, x1], [y0, y1], color='blue', alpha=0.5)

    # Axes
    ax.axhline(0, color='grey', linewidth=0.5)
    ax.axvline(0, color='grey', linewidth=0.5)

    ax.set_aspect('equal', 'box')
    LIM = R_OUTER + 10
    ax.set_xlim(-LIM, LIM)
    ax.set_ylim(-LIM, LIM)
    ax.set_xlabel("cm")
    ax.set_ylabel("cm")

    if title is not None:
        ax.set_title(title)

def overlay_night_figures(ax, pos_dict, label_text="Night figures sequence"):
    """
    Overlays a seasonal configuration of the 39 figures
    with the correct historical color sequence.
    """
    # light rays from the center
    for x, y in zip(pos_dict["x"], pos_dict["y"]):
        ax.plot([0, x], [0, y], color='red', alpha=0.12, linewidth=0.8)

    # colored points according to the sequence
    for k in range(N_FIG):
        x = pos_dict["x"][k]
        y = pos_dict["y"][k]
        col = NIGHT_SEQUENCE[k]["color_plot"]
        size = 38 if NIGHT_SEQUENCE[k]["color_name"] == "red" else 28
        ax.scatter([x], [y], s=size, c=col)

    # arc limits
    ang0 = np.deg2rad(pos_dict["start_deg"])
    ang1 = np.deg2rad(pos_dict["end_deg"])
    angc = np.deg2rad(pos_dict["center_deg"])

    x0, y0 = R_OUTER * np.cos(ang0), R_OUTER * np.sin(ang0)
    x1, y1 = R_OUTER * np.cos(ang1), R_OUTER * np.sin(ang1)
    xc, yc = R_OUTER * np.cos(angc), R_OUTER * np.sin(angc)

    ax.plot([0, x0], [0, y0], color='blue', linewidth=2)
    ax.plot([0, x1], [0, y1], color='blue', linewidth=2)
    ax.plot([0, xc], [0, yc], color='green', linewidth=1.5, linestyle='--')

    # dummy legend entries
    ax.scatter([], [], s=38, c='red', label="Red: sunset / geng start / sunrise")
    ax.scatter([], [], s=28, c='green', label="Green: curfew / intervals / wait dawn / xiao")

# ---------------------------------------------------------
# 1) Astronomical calculation over the whole year
# ---------------------------------------------------------

days   = np.arange(1, NDAYS + 1)
delta  = solar_declination_cooper(days)
daylen = day_length_hours(LAT_DEG, delta)

sunset = 12.0 + daylen / 2.0
mean_sunset = np.mean(sunset)
phase_hours = sunset - mean_sunset

nightlen = 24.0 - daylen
mean_nightlen = np.mean(nightlen)

print("Mean sunset time (approx): {:.2f} h".format(mean_sunset))
print("Phase range (hours): {:.3f} to {:.3f}".format(phase_hours.min(), phase_hours.max()))
print("Mean night length (approx): {:.2f} h".format(mean_nightlen))
print("Night length range (hours): {:.3f} to {:.3f}".format(nightlen.min(), nightlen.max()))

# ---------------------------------------------------------
# 2) Ideal lever angle and central gear angle
# ---------------------------------------------------------

trigger_angle_ideal_deg_all = phase_hours * DEG_PER_HOUR
input_angle_ideal_deg_all   = trigger_angle_ideal_deg_all / GEAR_RATIO
phi_des_all_rad             = deg2rad(input_angle_ideal_deg_all)

theta_all = 2.0 * pi * (days - 1) / NDAYS

# ---------------------------------------------------------
# 3) Inverse kinematics
# ---------------------------------------------------------

R = R_GEAR_CENTRAL
L = ROD_LENGTH_CM

g_all = phi_des_all_rad - theta_all
cos_g = np.cos(g_all)

A = 1.0
B = -2.0 * R * cos_g
C = R**2 - L**2

disc = B**2 - 4.0 * A * C
disc = np.maximum(disc, 0.0)
sqrt_disc = np.sqrt(disc)

d1 = (-B + sqrt_disc) / (2.0 * A)
d2 = (-B - sqrt_disc) / (2.0 * A)

radius_cam_all = np.where(
    np.abs(d1 - R0_CAM_CM) < np.abs(d2 - R0_CAM_CM),
    d1, d2
)

print("Cam radius range (cm): {:.2f} to {:.2f}".format(radius_cam_all.min(), radius_cam_all.max()))

# ---------------------------------------------------------
# 4) Sampling: 61 positions
# ---------------------------------------------------------

sample_days        = np.arange(1, NDAYS + 1, 6)
idx                = sample_days - 1

sample_phase_hours = phase_hours[idx]
sample_sunset      = sunset[idx]
sample_daylen      = daylen[idx]
sample_nightlen    = nightlen[idx]
sample_phi_des     = phi_des_all_rad[idx]
theta_year         = theta_all[idx]
theta_year_deg     = np.rad2deg(theta_year)

hole_radius = radius_cam_all[idx]
hole_x = hole_radius * np.cos(theta_year)
hole_y = hole_radius * np.sin(theta_year)

# ---------------------------------------------------------
# 4b) Positions of the 39 figures for the 61 samples
# ---------------------------------------------------------

night_figures_positions = []

for k, day in enumerate(sample_days):
    pos = compute_night_figures_positions(
        night_length_hours=sample_nightlen[k],
        mean_night_length_hours=mean_nightlen,
        n_fig=N_FIG,
        r_outer=R_OUTER,
        mean_arc_deg=MEAN_NIGHT_ARC_DEG,
        center_deg=NIGHT_CENTER_DEG
    )
    pos["day"] = int(day)
    night_figures_positions.append(pos)

idx_winter = np.argmax(sample_nightlen)
idx_summer = np.argmin(sample_nightlen)

print("\nSeasonal night figures:")
print("Winter sample day:", sample_days[idx_winter],
      "| night length = {:.2f} h".format(sample_nightlen[idx_winter]),
      "| arc = {:.2f}°".format(night_figures_positions[idx_winter]["night_arc_deg"]))
print("Summer sample day:", sample_days[idx_summer],
      "| night length = {:.2f} h".format(sample_nightlen[idx_summer]),
      "| arc = {:.2f}°".format(night_figures_positions[idx_summer]["night_arc_deg"]))

# ---------------------------------------------------------
# 5) Geometric reconstruction
# ---------------------------------------------------------

cos_g_geom = (R**2 + hole_radius**2 - L**2) / (2.0 * R * hole_radius)
cos_g_geom = np.clip(cos_g_geom, -1.0, 1.0)
gamma = np.arccos(cos_g_geom)

phi_cand1 = theta_year + gamma
phi_cand2 = theta_year - gamma

phi_geom = np.zeros_like(phi_cand1)

for k in range(len(sample_days)):
    phi_d = sample_phi_des[k]

    best_val = None
    best_err = 1e9

    for c in (phi_cand1[k], phi_cand2[k]):
        c_adj = c - 2.0 * np.pi * np.round((c - phi_d) / (2.0 * np.pi))
        err = abs(c_adj - phi_d)
        if err < best_err:
            best_err = err
            best_val = c_adj

    phi_geom[k] = best_val

# ---------------------------------------------------------
# 5b) Modulo 2π correction
# ---------------------------------------------------------

for k in range(len(sample_days)):
    diff = phi_geom[k] - sample_phi_des[k]
    if diff > np.pi:
        phi_geom[k] -= 2.0 * np.pi
    elif diff < -np.pi:
        phi_geom[k] += 2.0 * np.pi

# ---------------------------------------------------------
# 6) Centering and output angles
# ---------------------------------------------------------

phi_des_mean = np.mean(sample_phi_des)
phi_des_var  = sample_phi_des - phi_des_mean

phi_geom_mean = np.mean(phi_geom)
phi_geom_var  = phi_geom - phi_geom_mean

trigger_angle_ideal_deg = rad2deg(phi_des_var * GEAR_RATIO)
trigger_geom_deg        = rad2deg(phi_geom_var * GEAR_RATIO)

A_deg = np.max(np.abs(trigger_geom_deg))
A_hr  = A_deg / DEG_PER_HOUR

print(f"\nTrigger excursion ≈ ±{A_deg:.2f}°  (±{A_hr:.2f} h)")

print("\n[Geometric check – centered]")
print("Output trigger angle (ideal) range (deg): min={:.2f}, max={:.2f}".format(
    trigger_angle_ideal_deg.min(), trigger_angle_ideal_deg.max()))
print("Output trigger angle (geom)  range (deg): min={:.2f}, max={:.2f}".format(
    trigger_geom_deg.min(), trigger_geom_deg.max()))

# ---------------------------------------------------------
# DEBUG
# ---------------------------------------------------------

print("\n--- DEBUG: Days sampled ---")
print(sample_days)

phi_des_deg_dbg  = np.degrees(sample_phi_des)
phi_geom_deg_dbg = np.degrees(phi_geom)

print("\n--- DEBUG: Ideal vs Geometric (first 20 samples) ---")
for i in range(min(20, len(sample_days))):
    print(f"i={i:2d}, day={sample_days[i]:3d},  "
          f"ideal={phi_des_deg_dbg[i]:8.3f}°,   geom={phi_geom_deg_dbg[i]:8.3f}°,   "
          f"diff={phi_geom_deg_dbg[i]-phi_des_deg_dbg[i]:8.3f}°")

print("\n--- DEBUG: Full comparison ---")
diff_dbg = phi_geom_deg_dbg - phi_des_deg_dbg
threshold = 1.0
bad = np.where(np.abs(diff_dbg) > threshold)[0]

if len(bad) == 0:
    print("Perfect: no divergence > 1° over all 61 samples.")
else:
    first_bad = bad[0]
    print(f"The first divergence > {threshold}° occurs at sample:")
    print(f" index = {first_bad}, day = {sample_days[first_bad]}")
    print(f" ideal = {phi_des_deg_dbg[first_bad]:.3f}°,  "
          f"geom = {phi_geom_deg_dbg[first_bad]:.3f}°,  "
          f"diff = {diff_dbg[first_bad]:.3f}°")

print("\n--- DEBUG: Last 10 samples ---")
for i in range(max(0, len(sample_days)-10), len(sample_days)):
    print(f"i={i:2d}, day={sample_days[i]:3d},  "
          f"ideal={phi_des_deg_dbg[i]:8.3f}°,   geom={phi_geom_deg_dbg[i]:8.3f}°,   "
          f"diff={phi_geom_deg_dbg[i]-phi_des_deg_dbg[i]:8.3f}°")

