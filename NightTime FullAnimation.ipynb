import math
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation, FFMpegWriter
from math import pi

# =========================================================
# TWO-LEVEL AXONOMETRIC ANIMATION
# Orthographic projection from viewing direction (1, 1, 1)
# =========================================================

LAT_DEG = 34.80
NDAYS = 365

DIAM_INNER = 235.0
DIAM_OUTER = 250.0
R_INNER = DIAM_INNER / 2.0
R_OUTER = DIAM_OUTER / 2.0

R0_CAM_CM = 100.0
ROD_LENGTH_CM = 100.0

DEG_PER_HOUR = 15.0

R_GEAR_15 = 15.0
R_GEAR_30 = 30.0
GEAR_RATIO = R_GEAR_15 / R_GEAR_30

G1 = (0.0, 0.0)      # upper level, phase-control gear r=15
G2 = (45.0, 0.0)     # upper level, output gear r=30
G3 = (45.0, 0.0)     # lower level, driving gear r=30
G4 = (0.0, 0.0)      # lower level, cam gear r=15

N_RIBS = 31
N_ARROWS = 61
RIB_LEN_CM = 120.0

ANGLE_MIN = 144.95
ANGLE_MAX = 215.00

PIN_R_MIN = 0.42 * R_OUTER
PIN_R_MAX = 0.93 * R_OUTER

Z_LOWER = 0.0
Z_UPPER = 115.0

# ---------------------------------------------------------
# True orthographic projection from viewing direction (1,1,1)
# ---------------------------------------------------------

view = np.array([1.0, 1.0, 1.0])
view = view / np.linalg.norm(view)

e1 = np.array([1.0, -1.0, 0.0])
e1 = e1 / np.linalg.norm(e1)

e2 = np.cross(view, e1)
e2 = e2 / np.linalg.norm(e2)

def proj(x, y, z):
    p = np.array([x, y, -z])
    return np.dot(p, e1), np.dot(p, e2)

def draw_line_iso(ax, x1, y1, z1, x2, y2, z2, **kwargs):
    X1, Y1 = proj(x1, y1, z1)
    X2, Y2 = proj(x2, y2, z2)
    ax.plot([X1, X2], [Y1, Y2], **kwargs)

def draw_text_iso(ax, x, y, z, text, **kwargs):
    X, Y = proj(x, y, z)
    ax.text(X, Y, text, **kwargs)

def draw_circle_iso(ax, x, y, z, r, n=160, **kwargs):
    """
    Project a circle lying in the xy-plane at height z.
    Under the (1,1,1) projection it appears as an ellipse.
    """
    t = np.linspace(0, 2*np.pi, n)
    X, Y = [], []
    for a in t:
        xp = x + r*np.cos(a)
        yp = y + r*np.sin(a)
        Xp, Yp = proj(xp, yp, z)
        X.append(Xp)
        Y.append(Yp)
    ax.plot(X, Y, **kwargs)

def draw_point_iso(ax, x, y, z, r, n=48,
                   facecolor="black", edgecolor="none",
                   lw=0.5, zorder=10, alpha=1.0):
    """
    Project and fill a small circle lying in the xy-plane at height z.
    """
    t = np.linspace(0, 2*np.pi, n)
    X, Y = [], []
    for a in t:
        xp = x + r*np.cos(a)
        yp = y + r*np.sin(a)
        Xp, Yp = proj(xp, yp, z)
        X.append(Xp)
        Y.append(Yp)
    ax.fill(X, Y, facecolor=facecolor, edgecolor=edgecolor,
            lw=lw, zorder=zorder, alpha=alpha)

def deg2rad(x):
    return x * pi / 180.0

def rad2deg(x):
    return x * 180.0 / pi

def pt(ang_deg, r, ox=0.0, oy=0.0):
    a = math.radians(ang_deg)
    return ox + r * math.cos(a), oy + r * math.sin(a)

def solar_declination_cooper(N):
    return deg2rad(23.45) * np.sin(np.deg2rad(360.0 * (284.0 + N) / 365.0))

def day_length_hours(latitude_deg, delta_rad):
    phi = deg2rad(latitude_deg)
    x = -np.tan(phi) * np.tan(delta_rad)
    x = np.clip(x, -1.0, 1.0)
    H0 = np.arccos(x)
    return (2.0 * rad2deg(H0)) / 15.0

def rib_angles(span):
    spacing = span / (N_RIBS - 1)
    return [90 + (i - (N_RIBS - 1) / 2) * spacing for i in range(N_RIBS)]

def pin_radius(i):
    t = i / (N_RIBS - 1)
    if i % 2 == 0:
        return PIN_R_MIN + t * (PIN_R_MAX - PIN_R_MIN)
    return PIN_R_MAX - t * (PIN_R_MAX - PIN_R_MIN)

def draw_rotation_mark(ax, x, y, z, r, angle, color):
    x2 = x + 0.85 * r * math.cos(angle)
    y2 = y + 0.85 * r * math.sin(angle)
    draw_line_iso(ax, x, y, z, x2, y2, z,
                  color=color, lw=2.0, zorder=30)

def draw_level_plane(ax, z, label, color):
    corners = [(-145, -130), (145, -130), (145, 135), (-145, 135), (-145, -130)]
    X, Y = [], []
    for x, y in corners:
        xx, yy = proj(x, y, z)
        X.append(xx)
        Y.append(yy)
    ax.plot(X, Y, color=color, lw=0.9, alpha=0.55, zorder=0)
    draw_text_iso(ax, -140, 128, z, label,
                  fontsize=11, color=color,
                  ha="left", va="bottom", fontweight="bold")

# ---------------------------------------------------------
# Astronomical calculation
# ---------------------------------------------------------

days = np.arange(1, NDAYS + 1)

delta = solar_declination_cooper(days)
daylen = day_length_hours(LAT_DEG, delta)

sunset = 12.0 + daylen / 2.0
mean_sunset = np.mean(sunset)

phase_hours = sunset - mean_sunset
nightlen = 24.0 - daylen

trigger_angle_ideal_deg_all = phase_hours * DEG_PER_HOUR
input_angle_ideal_deg_all = trigger_angle_ideal_deg_all / GEAR_RATIO
phi_des_all_rad = deg2rad(input_angle_ideal_deg_all)

theta_all = 2.0 * pi * (days - 1) / NDAYS

R = R_GEAR_15
L = ROD_LENGTH_CM

g_all = phi_des_all_rad - theta_all
cos_g = np.cos(g_all)

B = -2.0 * R * cos_g
C = R**2 - L**2

disc = np.maximum(B**2 - 4.0 * C, 0.0)
sqrt_disc = np.sqrt(disc)

d1 = (-B + sqrt_disc) / 2.0
d2 = (-B - sqrt_disc) / 2.0

radius_cam_all = np.where(
    np.abs(d1 - R0_CAM_CM) < np.abs(d2 - R0_CAM_CM),
    d1,
    d2,
)

sample_days = np.arange(1, NDAYS + 1, 6)
idx = sample_days - 1

theta_year = theta_all[idx]
hole_radius = radius_cam_all[idx]
hole_x = hole_radius * np.cos(theta_year)
hole_y = hole_radius * np.sin(theta_year)

sample_phase_hours = phase_hours[idx]
sample_nightlen = nightlen[idx]

assert len(sample_days) == 61

phase_norm = (
    sample_phase_hours - sample_phase_hours.min()
) / (
    sample_phase_hours.max() - sample_phase_hours.min()
)

fan_span_samples = ANGLE_MIN + phase_norm * (ANGLE_MAX - ANGLE_MIN)

# ---------------------------------------------------------
# Figure and animation
# ---------------------------------------------------------

fig, ax = plt.subplots(figsize=(11, 10), dpi=130)
fig.patch.set_facecolor("#fafaf7")

def build_historical_colors(n=N_RIBS):
    """
    Reduced 31-figure visual sequence.
    Red = sunset / geng starts / sunrise.
    Green = intermediate signals.
    """
    colors = []

    colors.append("red")      # sunset
    colors.append("green")    # curfew

    for _ in range(5):
        colors.append("red")          # geng start
        colors.extend(["green"] * 4)  # four intervals

    colors.extend(["green"] * 20)     # safety padding

    colors = colors[:n]
    colors[-1] = "red"                # sunrise

    assert len(colors) == n
    return colors

FIGURE_COLORS = build_historical_colors()

def draw_cylinder_iso(ax, x, y, z, height=10, radius=2.0,
                      facecolor="green", edgecolor="black", zorder=40):
    """
    Small vertical cylinder standing at (x,y,z), projected in axonometry.
    Used for wooden figures at rib ends.
    """

    # bottom and top centers
    xb, yb = proj(x, y, z)
    xt, yt = proj(x, y, z + height)

    # side line
    ax.plot([xb, xt], [yb, yt],
            color=edgecolor, lw=1.0, zorder=zorder)

    # body as thick projected vertical segment
    ax.plot([xb, xt], [yb, yt],
            color=facecolor, lw=4.0, alpha=0.9,
            solid_capstyle="round", zorder=zorder+1)

    # top cap
    draw_point_iso(
        ax, x, y, z + height, radius,
        facecolor=facecolor,
        edgecolor=edgecolor,
        lw=0.4,
        zorder=zorder+2
    )

def draw_frame(k):
    ax.clear()
    ax.set_facecolor("#fafaf7")
    ax.set_aspect("equal")
    ax.axis("off")

    draw_level_plane(ax, Z_UPPER, "FOURTH LEVEL — phase control", "black")
    draw_level_plane(ax, Z_LOWER, "FIFTH LEVEL — fan positioning", "firebrick")

    # -----------------------------------------------------
    # Upper level: arrow wheel and phase gears
    # -----------------------------------------------------
    draw_circle_iso(ax, 0, 0, Z_UPPER, R_OUTER,
                    color="#222222", lw=1.1, zorder=2)
    draw_circle_iso(ax, 0, 0, Z_UPPER, R_INNER,
                    color="#666666", lw=0.9, linestyle="--", zorder=2)

    # cam profile
    cam_x_all = radius_cam_all * np.cos(theta_all)
    cam_y_all = radius_cam_all * np.sin(theta_all)
    Xc, Yc = [], []
    for x, y in zip(cam_x_all, cam_y_all):
        X, Y = proj(x, y, Z_UPPER)
        Xc.append(X)
        Yc.append(Y)
    ax.plot(Xc, Yc, color="#b8b8b8", lw=1.0, zorder=3)

    # 61 holes
    for j in range(N_ARROWS):
        draw_point_iso(ax, hole_x[j], hole_y[j], Z_UPPER, 1.45,
                       facecolor="white", edgecolor="black",
                       lw=0.55, zorder=5)

    # selected hole
    xh = hole_x[k]
    yh = hole_y[k]
    draw_point_iso(ax, xh, yh, Z_UPPER, 4.0,
                   facecolor="#c0392b", edgecolor="#7b1d12",
                   lw=0.9, zorder=20)

    # selected arrow-rod
    draw_line_iso(ax, 0, 0, Z_UPPER, xh, yh, Z_UPPER,
                  color="green", lw=2.0, alpha=0.85, zorder=18)

    # upper gears
    draw_circle_iso(ax, G1[0], G1[1], Z_UPPER, R_GEAR_15,
                    color="black", lw=1.8, zorder=22)
    draw_circle_iso(ax, G2[0], G2[1], Z_UPPER, R_GEAR_30,
                    color="black", lw=1.8, zorder=22)

    draw_text_iso(ax, G1[0]-20, G1[1]-20, Z_UPPER, "G1 r=15",
                  fontsize=8.5, color="black", ha="right")
    draw_text_iso(ax, G2[0]+33, G2[1]+5, Z_UPPER, "G2 r=30",
                  fontsize=8.5, color="black", ha="left")

    phi1 = theta_year[k]
    phi2 = -0.5 * phi1

    draw_rotation_mark(ax, G1[0], G1[1], Z_UPPER, R_GEAR_15, phi1, "black")
    draw_rotation_mark(ax, G2[0], G2[1], Z_UPPER, R_GEAR_30, phi2, "black")

    # -----------------------------------------------------
    # Vertical shaft between G2 and G3
    # -----------------------------------------------------
    draw_line_iso(ax, G2[0], G2[1], Z_UPPER, G3[0], G3[1], Z_LOWER,
                  color="darkred", lw=2.3, alpha=0.85, zorder=10)

    Xu, Yu = proj(G2[0], G2[1], (Z_UPPER + Z_LOWER) / 2)
    ax.text(Xu + 8, Yu,
            "common vertical shaft\nsame angle, same sense",
            fontsize=8.5, color="darkred",
            ha="left", va="center")

    # -----------------------------------------------------
    # Lower level: fan gears and fan ribs
    # -----------------------------------------------------
    draw_circle_iso(ax, G3[0], G3[1], Z_LOWER, R_GEAR_30,
                    color="red", lw=1.9, zorder=22)
    draw_circle_iso(ax, G4[0], G4[1], Z_LOWER, R_GEAR_15,
                    color="red", lw=1.9, zorder=22)

    draw_text_iso(ax, G3[0]+33, G3[1]+5, Z_LOWER, "G3 r=30",
                  fontsize=8.5, color="red", ha="left")
    draw_text_iso(ax, G4[0]-20, G4[1]-20, Z_LOWER, "G4 r=15",
                  fontsize=8.5, color="red", ha="right")

    phi3 = phi2
    phi4 = phi1

    draw_rotation_mark(ax, G3[0], G3[1], Z_LOWER, R_GEAR_30, phi3, "red")
    draw_rotation_mark(ax, G4[0], G4[1], Z_LOWER, R_GEAR_15, phi4, "red")

    # ghost fans
    for span, col, dash, alpha in [
        (ANGLE_MIN, "#b89270", (4, 3), 0.35),
        (ANGLE_MAX, "#6b4423", (2, 3), 0.22),
    ]:
        for theta in rib_angles(span):
            x2, y2 = pt(theta, RIB_LEN_CM)
            draw_line_iso(ax, 0, 0, Z_LOWER, x2, y2, Z_LOWER,
                          color=col, lw=0.6, dashes=dash,
                          alpha=alpha, zorder=4)

    # active fan
    span = fan_span_samples[k]
    angles = rib_angles(span)

    for i, theta in enumerate(angles):
        x2, y2 = pt(theta, RIB_LEN_CM)

        draw_line_iso(ax, 0, 0, Z_LOWER, x2, y2, Z_LOWER,
                      color="#6b4423", lw=1.35,
                      solid_capstyle="round", zorder=16)

        fig_col = FIGURE_COLORS[i]
        face = "#c0392b" if fig_col == "red" else "#2f8f46"

        draw_cylinder_iso(

            ax,
            x2, y2, Z_LOWER,
            height=10,
            radius=1.8,
            facecolor=face,
            edgecolor="#5a1a12" if fig_col == "red" else "#1f5f32",
            zorder=35
            )

        px, py = pt(theta, pin_radius(i))
        draw_point_iso(ax, px, py, Z_LOWER, 1.25,
                       facecolor="#c0392b", edgecolor="#7b1d12",
                       lw=0.35, zorder=18)

    # fan boundary rays
    x0, y0 = pt(angles[0], RIB_LEN_CM)
    x1, y1 = pt(angles[-1], RIB_LEN_CM)

    draw_line_iso(ax, 0, 0, Z_LOWER, x0, y0, Z_LOWER,
                  color="red", lw=2.0, alpha=0.8, zorder=19)
    draw_line_iso(ax, 0, 0, Z_LOWER, x1, y1, Z_LOWER,
                  color="red", lw=2.0, alpha=0.8, zorder=19)

    # pivots
    draw_point_iso(ax, 0, 0, Z_UPPER, 2.3,
                   facecolor="#2d2d2d", edgecolor="none", zorder=30)
    draw_point_iso(ax, 0, 0, Z_LOWER, 2.3,
                   facecolor="#2d2d2d", edgecolor="none", zorder=30)

    # dynamic text
    ax.text(0, 210,
            f"Two-level fan mechanism — annual setting {k+1}/61 — day {sample_days[k]}",
            fontsize=13, ha="center", va="center", color="#222")

    ax.text(0, 196,
            f"sunset phase = {sample_phase_hours[k]:+.2f} h · "
            f"fan opening = {span:.2f}° · "
            f"night length = {sample_nightlen[k]:.2f} h",
            fontsize=9.5, ha="center", va="center", color="#555")

    ax.text(-205, -175,
            "G1→G2 = 15:30, G3→G4 = 30:15; total ratio = 1, rotation sense preserved",
            fontsize=9, color="#333", ha="left")

    ax.set_xlim(-220, 240)
    ax.set_ylim(-195, 225)

def update(frame):
    draw_frame(frame % N_ARROWS)

anim = FuncAnimation(
    fig,
    update,
    frames=N_ARROWS,
    interval=150,
    blit=False,
    repeat=True,
)

mp4_path = "su_song_two_level_projected_fan.mp4"

writer = FFMpegWriter(fps=8, bitrate=3000)
anim.save(mp4_path, writer=writer)

print("MP4 saved as:", mp4_path)

plt.show()
